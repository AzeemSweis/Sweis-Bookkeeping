# Database
POSTGRES_URL=                    # Vercel Postgres connection string

# Auth
NEXTAUTH_SECRET=                 # Random secret for session encryption (generate with: openssl rand -base64 32)
NEXTAUTH_URL=https://hannasweis.com

# Admin credentials (used by seed script only — stored hashed in DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                  # Set before running seed script

# Email
RESEND_API_KEY=                  # Resend API key (https://resend.com)
CONTACT_EMAIL=hssweis@gmail.com  # Where contact form submissions are sent

# Blob storage
BLOB_READ_WRITE_TOKEN=           # Vercel Blob read/write token
